  <entry>
    <title>C语言第一套大题解答</title>
    <url>/2021/12/02/c-yu-yan-da-ti-jie-da/</url>
    <content><![CDATA[<p>``</p>
<span id="more"></span>
<p>第一套第一题</p>
<figure class="highlight bash"><table><tr><td class="code"><pre><span class="line"><span class="comment">#include &lt;conio.h&gt;</span></span><br><span class="line"><span class="comment">#include &lt;stdio.h&gt;</span></span><br><span class="line">void fun(int a, int b, long *c)</span><br><span class="line">&#123;</span><br><span class="line">	*c=(a/10)*1000+(a%10)*10+b/10+(b%10)*100;</span><br><span class="line">&#125;</span><br><span class="line"><span class="function"><span class="title">NONO</span></span> (  )</span><br><span class="line">&#123;/* 本函数用于打开文件，输入数据，调用函数，输出数据，关闭文件。 */</span><br><span class="line">  FILE *rf, *wf ;</span><br><span class="line">  int i, a,b ; long c ;</span><br><span class="line"></span><br><span class="line">  rf = fopen(<span class="string">&quot;in1.dat&quot;</span>, <span class="string">&quot;r&quot;</span>) ;</span><br><span class="line">  wf = fopen(<span class="string">&quot;bc06.dat&quot;</span>,<span class="string">&quot;w&quot;</span>) ;</span><br><span class="line">  <span class="keyword">for</span>(i = 0 ; i &lt; 10 ; i++) &#123;</span><br><span class="line">    fscanf(rf, <span class="string">&quot;%d,%d&quot;</span>, &amp;a, &amp;b) ;</span><br><span class="line">    fun(a, b, &amp;c) ;</span><br><span class="line">    fprintf(wf, <span class="string">&quot;a=%d,b=%d,c=%ld\n&quot;</span>, a, b, c) ;</span><br><span class="line">  &#125;</span><br><span class="line">  fclose(rf) ;</span><br><span class="line">  fclose(wf) ;</span><br><span class="line">&#125;</span><br><span class="line"><span class="function"><span class="title">main</span></span>()</span><br><span class="line">&#123;  int  a,b; long  c; </span><br><span class="line">   <span class="built_in">printf</span>(<span class="string">&quot;Input a, b:&quot;</span>);</span><br><span class="line">   scanf(<span class="string">&quot;%d,%d&quot;</span>, &amp;a, &amp;b);</span><br><span class="line">   fun(a, b, &amp;c);</span><br><span class="line">   <span class="built_in">printf</span>(<span class="string">&quot;The result is: %ld\n&quot;</span>, c);</span><br><span class="line">   NONO();</span><br><span class="line">&#125;</span><br></pre></td></tr></table></figure>
<p>第一套第二题</p>
<figure class="highlight bash"><table><tr><td class="code"><pre><span class="line"><span class="comment">#include &lt;stdio.h&gt;</span></span><br><span class="line"><span class="comment">#include &lt;conio.h&gt;</span></span><br><span class="line"></span><br><span class="line">double fun ( int n )</span><br><span class="line">&#123; double result = 1.0 ;</span><br><span class="line">/************FOUND************/</span><br><span class="line">  <span class="keyword">if</span>(n==0)</span><br><span class="line">    <span class="built_in">return</span> 1.0 ;</span><br><span class="line">  <span class="keyword">while</span>( n &gt;1 &amp;&amp; n &lt; 170 )</span><br><span class="line">/************FOUND************/</span><br><span class="line">    result *= n--;</span><br><span class="line">  <span class="built_in">return</span> result;</span><br><span class="line">&#125;</span><br><span class="line"></span><br><span class="line"><span class="function"><span class="title">main</span></span> ( )</span><br><span class="line">&#123; int n ;</span><br><span class="line">  <span class="built_in">printf</span>(<span class="string">&quot;Input N:&quot;</span>) ;</span><br><span class="line">  scanf(<span class="string">&quot;%d&quot;</span>, &amp;n) ;</span><br><span class="line">  <span class="built_in">printf</span>(<span class="string">&quot;\n\n%d! =%lf\n\n&quot;</span>, n, fun(n)) ;</span><br><span class="line">&#125;</span><br></pre></td></tr></table></figure>
<p>第一套第三题</p>
<figure class="highlight bash"><table><tr><td class="code"><pre><span class="line"><span class="comment">#include &lt;stdio.h&gt;</span></span><br><span class="line"></span><br><span class="line">struct stu_list</span><br><span class="line">&#123;</span><br><span class="line">  int num;</span><br><span class="line">  char name[20];</span><br><span class="line">  char sex;</span><br><span class="line">  <span class="built_in">float</span> score;</span><br><span class="line">&#125;s[5]=&#123;&#123;9801,<span class="string">&quot;Li Jie&quot;</span>,<span class="string">&#x27;M&#x27;</span>,56.5&#125;,</span><br><span class="line">       &#123;9802,<span class="string">&quot;Yang YiHang&quot;</span>,<span class="string">&#x27;M&#x27;</span>,83.5&#125;,</span><br><span class="line">       &#123;9803,<span class="string">&quot;Zhang Ping&quot;</span>,<span class="string">&#x27;F&#x27;</span>,90.5&#125;,</span><br><span class="line">       &#123;9804,<span class="string">&quot;Yuan Rui&quot;</span>,<span class="string">&#x27;F&#x27;</span>,93&#125;,</span><br><span class="line">       &#123;9805,<span class="string">&quot;Li Yanli&quot;</span>,<span class="string">&#x27;F&#x27;</span>,56&#125;</span><br><span class="line">      &#125;;</span><br><span class="line"></span><br><span class="line"><span class="function"><span class="title">main</span></span>()</span><br><span class="line">&#123;</span><br><span class="line">  int i,c=0;</span><br><span class="line">  <span class="built_in">float</span> ave,sum=0;</span><br><span class="line">  <span class="keyword">for</span> (i=0;i&lt;5;i++)</span><br><span class="line">  &#123;</span><br><span class="line">/***************found***************/  </span><br><span class="line">    sum+=s[i].score;</span><br><span class="line">/***************found***************/</span><br><span class="line">    <span class="keyword">if</span> (s[i].score&lt;60) c+=1;</span><br><span class="line">  &#125;</span><br><span class="line">  <span class="built_in">printf</span>(<span class="string">&quot;sum=%f \n&quot;</span>,sum);</span><br><span class="line">/***************found***************/</span><br><span class="line">  ave=sum/5.0;</span><br><span class="line">  <span class="built_in">printf</span>(<span class="string">&quot;average = %f \ncount= %d \n&quot;</span>,ave,c);</span><br><span class="line">  <span class="built_in">return</span>;</span><br><span class="line">  &#125;  </span><br></pre></td></tr></table></figure>
<p>``</p>
]]></content>

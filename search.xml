    <title>数据结构图的迪克斯查尔、曼彻斯特、普利姆等算法</title>
    <url>/2021/11/30/11-yue-30-ri-shi-yan-ke-nei-rong/</url>
    <content><![CDATA[<figure class="highlight bash"><table><tr><td class="code"><pre><span class="line"><span class="comment">#include &lt;stdio.h&gt;</span></span><br><span class="line">&lt;!--more--&gt;</span><br><span class="line"><span class="comment">#include &lt;memory.h&gt;</span></span><br><span class="line"><span class="comment">#define size 101</span></span><br><span class="line"><span class="comment">#define inf 32767</span></span><br><span class="line">typedef struct</span><br><span class="line">&#123;</span><br><span class="line">    int n,e;</span><br><span class="line">    int edge[size][size];</span><br><span class="line">&#125;mg;</span><br><span class="line"></span><br><span class="line">void init_mg(mg &amp;g)</span><br><span class="line">&#123;</span><br><span class="line">    g.n=g.e=0;</span><br><span class="line">    <span class="keyword">for</span> (int i = 1; i &lt; size; i++) &#123;</span><br><span class="line">        <span class="keyword">for</span> (int j = 0; j &lt; size; j++) &#123;</span><br><span class="line">            g.edge[i][j]=inf;</span><br><span class="line">        &#125;</span><br><span class="line"></span><br><span class="line">    &#125;</span><br><span class="line">&#125;</span><br><span class="line">void input(mg &amp;g)</span><br><span class="line">&#123;</span><br><span class="line">    freopen(<span class="string">&quot;in.txt&quot;</span>,<span class="string">&quot;r&quot;</span>,stdin);</span><br><span class="line">    scanf(<span class="string">&quot;%d%d&quot;</span>,&amp;g.n,&amp;g.e);</span><br><span class="line">    <span class="keyword">for</span> (int i = 1; i &lt;= g.e ; i++) &#123;</span><br><span class="line">        int v1,v2,w;</span><br><span class="line">        scanf(<span class="string">&quot;%d%d%d&quot;</span>,&amp;v1,&amp;v2,&amp;w);</span><br><span class="line">        g.edge[v1][v2]=g.edge[v2][v1]=w;</span><br><span class="line">    &#125;</span><br><span class="line">    fclose(stdin);</span><br><span class="line">&#125;</span><br><span class="line">typedef struct &#123;</span><br><span class="line">    int vs,ve,w;</span><br><span class="line">&#125;eg;</span><br><span class="line">void sort(eg g[],int e)</span><br><span class="line">&#123;</span><br><span class="line">    <span class="keyword">for</span> (int i = 1; i &lt; e; i++) &#123;</span><br><span class="line">        <span class="keyword">for</span> (int j = i+1; j &lt;= e; j++) &#123;</span><br><span class="line">            <span class="keyword">if</span>(g[i].w&gt;g[j].w)</span><br><span class="line">            &#123;</span><br><span class="line">                eg t=g[i];</span><br><span class="line">                g[i]=g[j];</span><br><span class="line">                g[j]=t;</span><br><span class="line">            &#125;</span><br><span class="line">        &#125;</span><br><span class="line"></span><br><span class="line">    &#125;</span><br><span class="line">&#125;</span><br><span class="line">void kruskal(mg g)</span><br><span class="line">&#123;</span><br><span class="line">    eg eg[size];</span><br><span class="line">    int ei=0;</span><br><span class="line">    <span class="keyword">for</span>(int i=1;i&lt;=g.n;i++)</span><br><span class="line">        <span class="keyword">for</span>(int j=1;j&lt;i;j++)</span><br><span class="line">            <span class="keyword">if</span>(g.edge[i][j]&lt;inf)</span><br><span class="line">            &#123;</span><br><span class="line">                ei++;</span><br><span class="line">                eg[ei].vs=i;</span><br><span class="line">                eg[ei].ve=j;</span><br><span class="line">                eg[ei].w=g.edge[i][j];</span><br><span class="line">            &#125;</span><br><span class="line">            sort(eg,ei);</span><br><span class="line">    int sn[size]=&#123;0&#125;;</span><br><span class="line">    <span class="keyword">for</span>(int i=1;i&lt;g.n;i++)</span><br><span class="line">        sn[i]=i;</span><br><span class="line">    int k=0;</span><br><span class="line">    ei=1;</span><br><span class="line">    <span class="keyword">while</span>(1)</span><br><span class="line">    &#123;</span><br><span class="line">        int vs,ve,w,sn1,sn2;</span><br><span class="line">        vs=eg[ei].vs;</span><br><span class="line">        ve=eg[ei].ve;</span><br><span class="line">        w=eg[ei].w;</span><br><span class="line">        sn1=sn[vs];</span><br><span class="line">        sn2=sn[ve];</span><br><span class="line">        <span class="keyword">if</span>(sn1!=sn2)</span><br><span class="line">        &#123;</span><br><span class="line">            <span class="built_in">printf</span>(<span class="string">&quot;(%d,%d)(%d),&quot;</span>,ve,vs,w);</span><br><span class="line">            k++;</span><br><span class="line">            <span class="keyword">if</span>(k==g.n-1) <span class="built_in">break</span>;</span><br><span class="line">            <span class="keyword">for</span>(int i=1;i&lt;=g.n;i++)</span><br><span class="line">            &#123;</span><br><span class="line">                <span class="keyword">if</span>(sn[i]==sn2) sn[i]=sn1;</span><br><span class="line">            &#125;</span><br><span class="line">        &#125;</span><br><span class="line">        ei++;</span><br><span class="line">    &#125;</span><br><span class="line">&#125;</span><br><span class="line">int Min(eg eg[],int n)</span><br><span class="line">&#123;</span><br><span class="line">	int min=inf,mini=0;</span><br><span class="line">	<span class="keyword">for</span>(int i=1;i&lt;n;i++)</span><br><span class="line">		<span class="keyword">if</span>(min&gt;eg[i].w)</span><br><span class="line">		&#123;</span><br><span class="line">			min=eg[i].w;</span><br><span class="line">			mini=i;</span><br><span class="line">		&#125;</span><br><span class="line">	<span class="built_in">return</span> mini;</span><br><span class="line">&#125;</span><br><span class="line">void pulimu(mg g)</span><br><span class="line">&#123;</span><br><span class="line">	int b[size]=&#123;0&#125;;</span><br><span class="line">	b[1]=1;</span><br><span class="line">	int k=1;</span><br><span class="line">	<span class="keyword">while</span>(k&lt;g.n)</span><br><span class="line">	&#123;</span><br><span class="line">		eg eg[size];</span><br><span class="line">		int ei=0;</span><br><span class="line">		<span class="keyword">for</span>(int i=1;i&lt;=g.n;i++)</span><br><span class="line">			<span class="keyword">for</span>(int j=1;j&lt;=g.n;j++)</span><br><span class="line">				<span class="keyword">if</span>(b[i]&amp;&amp;!b[j]&amp;&amp;g.edge[i][j]&lt;inf)</span><br><span class="line">				&#123;</span><br><span class="line">					ei++;</span><br><span class="line">					eg[ei].vs=i;eg[ei].ve=j;</span><br><span class="line">					eg[ei].w=g.edge[i][j];</span><br><span class="line">				&#125;</span><br><span class="line">				int m=Min(eg,ei);</span><br><span class="line">				<span class="built_in">printf</span>(<span class="string">&quot;(%d,%d)(%d),&quot;</span>,eg[m].vs,eg[m].ve,eg[m].w);</span><br><span class="line">				b[eg[m].ve]=1;</span><br><span class="line">				k++;</span><br><span class="line">	&#125;</span><br><span class="line">&#125;</span><br><span class="line">int serchmin(int lamd[],bool blamd[],int n)</span><br><span class="line">&#123;</span><br><span class="line">	int k=1;</span><br><span class="line">	int min=inf;</span><br><span class="line">	<span class="keyword">for</span>(int i=1;i&lt;=n;i++)</span><br><span class="line">	&#123;</span><br><span class="line">		<span class="keyword">if</span>(min&gt;lamd[i]&amp;&amp;!blamd[i])</span><br><span class="line">		&#123;</span><br><span class="line">			k=i;</span><br><span class="line">			min=lamd[i];</span><br><span class="line">		&#125;</span><br><span class="line">	&#125;</span><br><span class="line">	<span class="built_in">return</span> k;</span><br><span class="line">&#125;</span><br><span class="line">void dikesiche(mg g,int vstart)</span><br><span class="line">&#123;</span><br><span class="line">	int lamd[size],dis[size][size];</span><br><span class="line">	bool blamd[size];</span><br><span class="line">    memset(lamd,inf,100);</span><br><span class="line">	memset(blamd,<span class="literal">false</span>,100);</span><br><span class="line">	<span class="built_in">printf</span>(<span class="string">&quot;%d&quot;</span>,g.n);</span><br><span class="line">	<span class="keyword">for</span>(int i=1;i&lt;=g.n;i++)</span><br><span class="line">		<span class="keyword">for</span>(int j=1;j&lt;=g.n;i++)</span><br><span class="line">			dis[i][j]=g.edge[i][j];</span><br><span class="line">	blamd[vstart]=<span class="literal">true</span>;</span><br><span class="line">	<span class="keyword">for</span>(int i=1;i&lt;=g.n;i++)</span><br><span class="line">	&#123;</span><br><span class="line">		lamd[i]=dis[vstart][i];</span><br><span class="line">	&#125;</span><br><span class="line">	<span class="keyword">for</span>(int i=2;i&lt;=g.n;i++)</span><br><span class="line">	&#123;</span><br><span class="line">		int k=serchmin(lamd,blamd,g.n);</span><br><span class="line">		blamd[k]=<span class="literal">true</span>;</span><br><span class="line">		<span class="built_in">printf</span>(<span class="string">&quot;%d(%d),&quot;</span>,k,lamd[k]);</span><br><span class="line">		<span class="keyword">for</span>(int j=1;j&lt;=g.n;j++)</span><br><span class="line">		&#123;</span><br><span class="line">			<span class="keyword">if</span>(lamd[j]&gt;lamd[k]+dis[k][j])</span><br><span class="line">				lamd[j]=lamd[k]+dis[k][j];</span><br><span class="line">		&#125;</span><br><span class="line">	&#125;</span><br><span class="line">&#125;</span><br><span class="line">int <span class="function"><span class="title">main</span></span>()</span><br><span class="line">&#123;</span><br><span class="line">    mg g;</span><br><span class="line">    init_mg(g);</span><br><span class="line">    input(g);</span><br><span class="line">    <span class="built_in">printf</span>(<span class="string">&quot;%d&quot;</span>,g.n);</span><br><span class="line">    kruskal(g);</span><br><span class="line">    pulimu(g);</span><br><span class="line">	dikesiche(g,1);</span><br><span class="line">    <span class="built_in">return</span> 0;</span><br><span class="line">&#125;</span><br><span class="line"></span><br><span class="line"></span><br><span class="line"></span><br><span class="line"></span><br><span class="line"></span><br><span class="line"></span><br><span class="line"></span><br><span class="line"></span><br><span class="line"></span><br><span class="line"></span><br></pre></td></tr></table></figure>
]]></content>
